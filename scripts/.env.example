# Variables de entorno para Funding Arbitrage Bot
# Copia este archivo como .env y rellena con tus claves

# Hyperliquid API wallet (generar en https://app.hyperliquid.xyz/API)
HYPERLIQUID_API_KEY=tu_api_wallet_address_0x
HYPERLIQUID_API_SECRET=tu_api_wallet_private_key_larga
HYPERLIQUID_WALLET_ADDRESS=tu_wallet_principal_0x

# Telegram bot (opcional pero recomendado)
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=tu_chat_id_numerico
